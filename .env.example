# ─── App ──────────────────────────────────────────────────────────
APP_NAME=KG Ticket Control
SECRET_KEY=change-this-to-a-long-random-string

# ─── Storage ──────────────────────────────────────────────────────
# "local"    → JSON file at LOCAL_STORE_PATH (good for dev)
# "firebase" → Firestore (good for prod / shared data)
APP_STORAGE_MODE=firebase
LOCAL_STORE_PATH=data/phase1_store.json

# ─── Firebase / Firestore ─────────────────────────────────────────
FIREBASE_PROJECT_ID=kg-ticket
# Either point to a service-account JSON file on disk:
# FIREBASE_CREDENTIALS=./serviceAccount.json
# OR paste the entire JSON service-account content here (preferred for Vercel/Render):
FIREBASE_CREDENTIALS_JSON=

# Optional Firebase Auth (web API key) — for Firebase-authenticated logins
AUTH_PROVIDER=local
FIREBASE_API_KEY=AIzaSyDtxIe7TOqoc-Ug9TegPtVc7GdNs0ki2QA
