# =============================================================================
# KG Ticket Control — environment template
# Copy this to .env (local) or paste each line into Vercel's Environment Variables.
# =============================================================================

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=KG Ticket Control

# Long random string. Used for Flask session signing.
# A fresh one was generated for you below — replace with your own if you prefer.
SECRET_KEY=UPhB7Vi_B^TVyG_PTU@n$Yh3JkH0o8qOLFsFnI5uT5*aWmyFEXES3rRCSvw3iE0U

# ─── Storage ─────────────────────────────────────────────────────────────────
# "firebase" = Firestore (recommended for Vercel and shared/multi-user data)
# "local"    = JSON file at LOCAL_STORE_PATH (single-user dev only)
APP_STORAGE_MODE=firebase
LOCAL_STORE_PATH=data/phase1_store.json

# ─── Authentication ──────────────────────────────────────────────────────────
# "firebase" = Firebase Identity Toolkit (login validated by Google)
# "local"    = werkzeug password hash check against the local users collection
AUTH_PROVIDER=firebase

# Firebase Web API key — found at:
#   https://console.firebase.google.com/project/kg-ticket/settings/general
#   under "Your apps" → "Web SDK setup" → apiKey
# This is safe to ship in client-side code; security comes from Firestore Rules.
FIREBASE_API_KEY=AIzaSyDtxIe7TOqoc-Ug9TegPtVc7GdNs0ki2QA

# ─── Firebase / Firestore (server-side admin SDK) ────────────────────────────
FIREBASE_PROJECT_ID=kg-ticket

# Pick exactly ONE of the two options below:
#
# Option A — local development:
#   1. Download a service-account JSON from
#      https://console.firebase.google.com/project/kg-ticket/settings/serviceaccounts/adminsdk
#      (click "Generate new private key")
#   2. Save it as serviceAccount.json in the project root (already in .gitignore)
#   3. Uncomment the next line:
# FIREBASE_CREDENTIALS=./serviceAccount.json
#
# Option B — Vercel / Render / any cloud host:
#   Paste the entire JSON file content as the value below.
#   Vercel preserves newlines in env-var inputs, so multi-line is fine.
FIREBASE_CREDENTIALS_JSON=
